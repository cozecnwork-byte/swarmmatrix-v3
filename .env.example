# ============================================
# GlobalLeadGen v3 环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填入真实配置值
# ============================================

# ============================================
# 1. Supabase 数据库配置
# ============================================
# 从 Supabase 项目设置中获取
COZE_SUPABASE_URL=https://your-project-id.supabase.co
COZE_SUPABASE_ANON_KEY=your-supabase-anon-key
COZE_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# 2. LLM (大语言模型) 配置
# ============================================
# 使用 coze-coding-dev-sdk 的配置
# 参考：https://github.com/coze-coding/coze-coding-dev-sdk

# Coze API 配置（如果使用 Coze）
COZE_API_KEY=your-coze-api-key
COZE_BOT_ID=your-bot-id

# 其他 LLM 提供商（可选）
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# KIMI_API_KEY=your-kimi-api-key

# ============================================
# 3. 社交平台 API 配置
# ============================================
# TikTok / 抖音
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_APP_ID=your-tiktok-app-id
TIKTOK_APP_SECRET=your-tiktok-app-secret

# Instagram
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# Twitter / X
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# 小红书
XIAOHONGSHU_ACCESS_TOKEN=your-xiaohongshu-access-token
XIAOHONGSHU_APP_ID=your-xiaohongshu-app-id
XIAOHONGSHU_APP_SECRET=your-xiaohongshu-app-secret

# B站
BILIBILI_ACCESS_TOKEN=your-bilibili-access-token
BILIBILI_COOKIE=your-bilibili-cookie

# ============================================
# 4. 对象存储配置 (S3 兼容)
# ============================================
# 用于存储图片、视频等媒体文件
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_REGION=us-east-1

# 或使用其他 S3 兼容存储（如阿里云 OSS、腾讯云 COS 等）
# S3_ENDPOINT=https://your-custom-endpoint.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=your-bucket

# ============================================
# 5. 代理配置（IP 代理）
# ============================================
# 用于多地区 IP 切换
PROXY_POOL_URL=http://your-proxy-pool.com
PROXY_USERNAME=your-proxy-username
PROXY_PASSWORD=your-proxy-password

# 按国家配置代理
PROXY_CN=http://cn-proxy:port
PROXY_US=http://us-proxy:port
PROXY_JP=http://jp-proxy:port
PROXY_UK=http://uk-proxy:port

# ============================================
# 6. 定时任务配置
# ============================================
# 使用 Vercel Cron 或其他调度服务
CRON_ENABLED=true
CRON_SCHEDULE=0 * * * * # 每小时执行

# ============================================
# 7. 分析和监控配置
# ============================================
# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX

# 错误追踪（可选）
SENTRY_DSN=your-sentry-dsn

# ============================================
# 8. 其他配置
# ============================================
# 应用基础 URL（用于回调等）
NEXT_PUBLIC_APP_URL=https://your-domain.com

# 环境标识
NODE_ENV=production # 或 development

# ============================================
# 获取配置的说明
# ============================================
#
# 1. Supabase:
#    - 访问 https://supabase.com/dashboard
#    - 创建新项目或选择现有项目
#    - 在 Project Settings -> API 中获取 URL 和 keys
#
# 2. 各平台 API:
#    - TikTok: https://developers.tiktok.com/
#    - Instagram: https://developers.facebook.com/
#    - YouTube: https://console.cloud.google.com/
#    - Twitter: https://developer.twitter.com/
#    - LinkedIn: https://developer.linkedin.com/
#    - 小红书: https://developer.xiaohongshu.com/
#    - B站: https://open.bilibili.com/
#
# 3. 代理服务:
#    - 推荐使用 BrightData、Oxylabs、Smartproxy 等
#    - 或自建代理池
#
# ============================================
